CLOUDFLARE_X-AUTH-EMAIL=your_email_here
CLOUDFLARE_X-AUTH-KEY=your_api_key_here

# Zones — one CLOUDFLARE_ZONE_ID_<SUFFIX> per zone
# The suffix becomes the zone label in reports (lowercased)
# Sitemaps are optional — only needed for the "report" command
CLOUDFLARE_ZONE_ID_SK=your_zone_id_here
CLOUDFLARE_ZONE_SITEMAP_SK=https://gymbeam.sk/sitemap.xml

CLOUDFLARE_ZONE_ID_CZ=your_zone_id_here
CLOUDFLARE_ZONE_SITEMAP_CZ=https://gymbeam.cz/sitemap.xml

# Fallback: single zone (used if no CLOUDFLARE_ZONE_ID_* vars are set)
# CLOUDFLARE_ZONE_ID=your_zone_id_here
